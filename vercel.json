{
  "rewrites": [
    {
      "source": "/baseball/statpad/:path*",
      "destination": "https://coherency1.github.io/baseball-games/:path*"
    },
    {
      "source": "/baseball/statpad",
      "destination": "https://coherency1.github.io/baseball-games/"
    },
    {
      "source": "/baseball/deadeye/:path*",
      "destination": "https://coherency1.github.io/deadeye/:path*"
    },
    {
      "source": "/baseball/deadeye",
      "destination": "https://coherency1.github.io/deadeye/"
    },
    {
      "source": "/baseball/:path*",
      "destination": "/pages/baseball/:path*"
    },
    {
      "source": "/baseball",
      "destination": "/pages/baseball/index.html"
    }
  ]
}
