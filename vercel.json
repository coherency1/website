{
  "buildCommand": "node -e \"require('fs').writeFileSync('pages/baseball/turso-config.json', JSON.stringify({url:process.env.TURSO_URL,token:process.env.TURSO_TOKEN}))\"",
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/baseball",
      "destination": "/baseball/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/baseball/deadeye",
      "destination": "/pages/baseball/deadeye/index.html"
    },
    {
      "source": "/baseball/deadeye/",
      "destination": "/pages/baseball/deadeye/index.html"
    },
    {
      "source": "/baseball/deadeye/:path*",
      "destination": "/pages/baseball/deadeye/:path*"
    },
    {
      "source": "/baseball/statpad",
      "destination": "/pages/baseball/statpad/index.html"
    },
    {
      "source": "/baseball/statpad/",
      "destination": "/pages/baseball/statpad/index.html"
    },
    {
      "source": "/baseball/statpad/:path*",
      "destination": "/pages/baseball/statpad/:path*"
    },
    {
      "source": "/baseball/fantasy",
      "destination": "/pages/baseball/fantasy/index.html"
    },
    {
      "source": "/baseball/fantasy/",
      "destination": "/pages/baseball/fantasy/index.html"
    },
    {
      "source": "/baseball/",
      "destination": "/pages/baseball/index.html"
    },
    {
      "source": "/baseball/:path*",
      "destination": "/pages/baseball/:path*"
    }
  ]
}
