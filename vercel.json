{
  "redirects": [
    {
      "source": "/baseball",
      "destination": "/baseball/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/baseball/statpad/:path*",
      "destination": "https://coherency1.github.io/baseball-games/statpad/:path*"
    },
    {
      "source": "/baseball/statpad/",
      "destination": "https://coherency1.github.io/baseball-games/statpad/"
    },
    {
      "source": "/baseball/statpad",
      "destination": "https://coherency1.github.io/baseball-games/statpad/"
    },
    {
      "source": "/baseball/deadeye/:path*",
      "destination": "https://coherency1.github.io/baseball-games/deadeye/:path*"
    },
    {
      "source": "/baseball/deadeye/",
      "destination": "https://coherency1.github.io/baseball-games/deadeye/"
    },
    {
      "source": "/baseball/deadeye",
      "destination": "https://coherency1.github.io/baseball-games/deadeye/"
    },
    {
      "source": "/baseball/fantasy",
      "destination": "/pages/baseball/fantasy/index.html"
    },
    {
      "source": "/baseball/fantasy/",
      "destination": "/pages/baseball/fantasy/index.html"
    },
    {
      "source": "/baseball/",
      "destination": "/pages/baseball/index.html"
    },
    {
      "source": "/baseball/:path*",
      "destination": "/pages/baseball/:path*"
    }
  ]
}
